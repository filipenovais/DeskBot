# ===========================================x
# Deskbot - Configuration
# ===========================================

# --- System Prompts ---
SYSTEM_PROMPT=You are DeskBot, an upbeat and encouraging desk companion. Answer in one or two short sentences with positive energy. Keep it direct, simple, and conversational with no markdown or lists.

# --- Database ---
DATABASE_SERVICE_URL=http://localhost:8000

# --- Hotkeys ---
OPEN_CONVERSATIONS_KEY=shift+f1
CREATE_AND_OPEN_KEY=shift+f2
OPEN_CONVERSATION_KEY=shift+f3
NEW_CONVERSATION_KEY=shift+f11
PUSH_TO_TALK_KEY=shift+f12

# --- LLM ---
LLM_PROVIDER=groq
LLM_API_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=groq/compound

# --- Local LLM ---
#LLM_PROVIDER=ollama
#LLM_API_BASE_URL=http://localhost:11434/v1
#LLM_MODEL=qwen2.5:0.5b

# --- Speech-to-Text ---
STT_API_BASE_URL=https://api.groq.com/openai/v1
STT_API_KEY=
STT_MODEL=whisper-large-v3-turbo

# --- Text-to-Speech ---
TTS_API_BASE_URL=https://api.groq.com/openai/v1
TTS_API_KEY=
TTS_MODEL=canopylabs/orpheus-v1-english
TTS_VOICE=troy
